\subsection{Computational Cost Analysis}
\label{sec:cost}

% Purpose:
% Address reviewer concern about OT overhead.

We analyze the computational overhead introduced by OT-based negative generation by measuring wall-clock training time per epoch. We report the relative increase in training time compared to baseline contrastive learning and examine the impact of OT update frequency and transport locality.

\subsection{Qualitative Analysis}
\label{sec:qualitative}

% Optional but recommended:
% Visualize nearest neighbors and synthetic negatives.

We provide qualitative retrieval examples and visualize OT-generated synthetic negatives to illustrate the types of semantic confusions captured by the transport-based formulation.

\begin{algorithm}[t]
\caption{OT-Augmented Multimodal Contrastive Training}
\label{alg:ot_training}

\KwIn{
    Dataset $\mathcal{D}$ of image--text pairs; \\
    Image encoder $f_I$, text encoder $f_T$; \\
    Projection heads $W_I$, $W_T$; \\
    Temperature $\tau$; \\
    OT update interval $k$; \\
    Warm-up steps $t_{\mathrm{warm}}$; \\
    Ramp length $t_{\mathrm{ramp}}$; \\
    Maximum OT weight $\alpha_{\max}$; \\
    OT configuration (regularization, iterations, etc.); \\
    Batch size $B$.
}

\KwOut{
    Trained model parameters $\theta$.
}

Initialize parameters $\theta$ (encoders + projection heads)\;
Initialize optimizer (e.g., Adam)\;
Construct pairwise label matrix $Y \in \{0,1\}^{B \times B}$ with $Y_{ij} = \mathbb{1}[i=j]$\;
Set \texttt{ot\_active} $\leftarrow$ \textbf{False}, $\tilde{Z}^I \leftarrow$ \textbf{None}\;

\For{training step $t = 1,2,\dots, T$}{
    Sample minibatch $\{(I_i, T_i)\}_{i=1}^B \sim \mathcal{D}$\;
    Apply image augmentations to $\{I_i\}$\;

    \tcp{Encode images and text}
    $H^I \leftarrow f_I(I_1, \dots, I_B)$\;
    $H^T \leftarrow f_T(T_1, \dots, T_B)$\;
    $Z^I \leftarrow \text{L2Norm}(W_I H^I)$\;
    $Z^T \leftarrow \text{L2Norm}(W_T H^T)$\;

    \tcp{Similarity matrix and sigmoid contrastive loss}
    $S \leftarrow \text{SimMatrix}(Z^I, Z^T, \tau)$\;
    $L_{\mathrm{sig}} \leftarrow \text{SigmoidContrastiveLoss}(S, Y)$\;

    \tcp{Compute current OT weight}
    $\alpha \leftarrow \text{AlphaSchedule}(t, t_{\mathrm{warm}}, t_{\mathrm{ramp}}, \alpha_{\max})$\;

    \tcp{Periodic OT update}
    \If{$t \ge t_{\mathrm{warm}}$ \textbf{and} $t \bmod k = 0$}{
        \texttt{ot\_active} $\leftarrow$ \textbf{True}\;
        $C \leftarrow \text{BuildOTCostMatrix}(Z^T, Z^I)$ \tcp*{$C_{ij} = 1 - \langle z_i^T, z_j^I \rangle$}
        $C \leftarrow \text{MaskDiagonal}(C, M)$ \tcp*{avoid self-matching}
        $\Pi \leftarrow \text{ComputeOTPlan}(C, \text{OT config})$ \tcp*{transport plan}
        $W \leftarrow \text{RowNormalize}(\Pi)$\;
        $\tilde{Z}^I \leftarrow \text{BarycentricProjection}(W, Z^I)$\;
        $\tilde{Z}^I \leftarrow \text{StopGradient}(\tilde{Z}^I)$\;
    }

    \tcp{OT-negative loss}
    \eIf{\texttt{ot\_active} \textbf{and} $\alpha > 0$}{
        $L_{\mathrm{OTneg}} \leftarrow 0$\;
        \For{$i = 1$ \KwTo $B$}{
            $s_{\mathrm{pos}} \leftarrow \langle z_i^I, z_i^T \rangle / \tau$\;
            $s_{\mathrm{neg}} \leftarrow \langle \tilde{z}_i^I, z_i^T \rangle / \tau$\;
            $L_{\mathrm{OTneg}} \mathrel{+}= 
                - \log \left(
                    \frac{e^{s_{\mathrm{pos}}}}
                         {e^{s_{\mathrm{pos}}} + e^{s_{\mathrm{neg}}}}
                \right)$\;
        }
        $L_{\mathrm{OTneg}} \leftarrow L_{\mathrm{OTneg}} / B$\;
    }{
        $L_{\mathrm{OTneg}} \leftarrow 0$\;
    }

    \tcp{Total loss and optimizer update}
    $L \leftarrow L_{\mathrm{sig}} + \alpha \cdot L_{\mathrm{OTneg}}$\;
    Update parameters $\theta$ with gradient $\nabla_\theta L$\;
}

\end{algorithm}








